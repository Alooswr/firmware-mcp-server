{
  "devices": [
    {
      "device_id": "demo",
      "build": {
        "command": ["make"],
        "cwd": "/path/to/firmware/project"
      },
      "flash": {
        "command": ["make", "flash"],
        "cwd": "/path/to/firmware/project"
      },
      "reset": {
        "command": ["python", "scripts/reset.py"],
        "cwd": "/path/to/firmware/project"
      },
      "serial": {
        "port": "COM3",
        "baudrate": 115200,
        "timeout_ms": 3000
      }
    }
  ]
}
